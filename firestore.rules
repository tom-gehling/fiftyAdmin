rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isMember(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
          && get(/databases/$(database)/documents/users/$(uid)).data.isMember == true;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Venues — public read for active/non-deleted venues, admin write
    match /venues/{id} {
      allow read: if resource.data.isActive == true && resource.data.deletedAt == null;
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Quizzes
    match /quizzes/{id} {
      allow read: if true;
      allow write: if isAuthenticated()
                   && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    // Quiz tags
    match /quizTags/{id} {
      allow read: if true;
      allow write: if isAuthenticated()
                   && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    // Admins collection
    match /admins/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Users — own doc or admin can read, only own doc can write
    match /users/{userId} {
      allow read: if isAuthenticated()
                  && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Submission forms — any auth can read, admins can write
    match /submissionForms/{formId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Quiz results — members can write their own, users/admins can read
    match /quizResults/{resultId} {
      allow create, update: if isAuthenticated()
                            && isMember(request.auth.uid)
                            && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /quizTotalStats/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /quizAggregates/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
